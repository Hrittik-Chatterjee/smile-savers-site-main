# Elite AI Workforce Configuration
GITHUB_TOKEN=your_token_here
GOOGLE_PROJECT_ID=your_project_id
OPENAI_API_KEY=your_key

# TinaCMS — TinaCloud credentials
# Client ID: from app.tina.io → your project → Application IDs
TINA_CLIENT_ID=your_tina_client_id_here
# Token: from app.tina.io → your project → Tokens → Content token
TINA_TOKEN=your_tina_content_token_here
# Branch to use for content (usually main)
GITHUB_BRANCH=main
