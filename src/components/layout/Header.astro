---
/**
 * Header — Enhanced · accent CTA · Appointments highlighted in nav · mobile phone text
 */
import Navigation from './Navigation.astro';
import MobileMenu from './MobileMenu.astro';
import { siteConfig } from '@/config/site';
import { ctaButton } from '@/config/navigation';
import { formatPhoneLink } from '@/lib/utils';
---

<div class="header-row">
  <header class="site-header" id="site-header">
    <div class="header-container">

      <!-- Logo -->
      <a href="/" class="logo" aria-label={`${siteConfig.name} — Home`}>
        <img src="/logo.svg" alt={siteConfig.name} class="logo-icon" width="180" height="36" />
      </a>

      <!-- Desktop nav -->
      <Navigation />

      <!-- Desktop actions -->
      <div class="desktop-actions">
        <a href={ctaButton.href} class="hdr-cta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {ctaButton.label}
        </a>
      </div>

      <!-- Mobile actions -->
      <div class="mobile-actions">
        {siteConfig.social.facebook && (
          <a href={siteConfig.social.facebook} class="mob-icon" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        )}
        <a href={formatPhoneLink(siteConfig.phone)} class="mob-call" aria-label="Call us">
          <svg class="phone-ring-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span class="mob-call-num">{siteConfig.phone}</span>
        </a>
      </div>

    </div>
  </header>
  <MobileMenu />
</div>

<style>
@keyframes phone-ring{0%,100%,50%{transform:rotate(0)}10%{transform:rotate(14deg)}20%{transform:rotate(-11deg)}30%{transform:rotate(8deg)}40%{transform:rotate(-4deg)}}
.phone-ring-icon{animation:phone-ring 4s ease-in-out 2s 2;transform-origin:center}
@media(prefers-reduced-motion:reduce){.phone-ring-icon{animation:none}}

.header-row{
  position:sticky;top:.75rem;left:0;right:0;
  z-index:var(--z-sticky);
  margin:.75rem;
  display:flex;align-items:center;gap:.5rem;
}
@media(max-width:480px){.header-row{top:.5rem;margin:.5rem}}

.site-header{
  flex:1;min-width:0;
  background:color-mix(in srgb,var(--color-surface-elevated) 93%,transparent);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid transparent;
  border-radius:var(--radius-xl);
  transition:border-color .3s ease,box-shadow .3s ease;
}
.site-header.scrolled{
  border-color:var(--color-border);
  box-shadow:0 4px 24px rgba(16,43,63,.1);
}
@media(max-width:480px){.site-header{border-radius:var(--radius-lg)}}

.header-container{
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  max-width:var(--container-xl);margin-inline:auto;
  padding:.75rem var(--spacing-element);
}
@media(max-width:768px){.header-container{padding:.5rem .875rem}}

.logo{display:flex;align-items:center;text-decoration:none;transition:opacity .2s}
.logo:hover{opacity:.85}
.logo:focus-visible{outline:2px solid var(--color-accent);outline-offset:4px;border-radius:var(--radius-sm)}
.logo-icon{max-width:clamp(120px,35vw,180px);height:auto;flex-shrink:0}

/* Desktop CTA */
.desktop-actions{display:flex;align-items:center}
.hdr-cta{
  display:inline-flex;align-items:center;gap:.4rem;
  padding:.6rem 1.25rem;
  border-radius:.65rem;
  background:var(--color-accent);
  color:#fff;
  font-weight:700;font-size:.85rem;
  text-decoration:none;
  box-shadow:0 3px 12px rgba(44,171,223,.35);
  transition:all .25s ease;
  white-space:nowrap;
}
.hdr-cta:hover{background:var(--color-accent-dark);transform:translateY(-1px);box-shadow:0 6px 20px rgba(44,171,223,.45)}

/* Mobile actions */
.mobile-actions{display:none;align-items:center;gap:.25rem}
.mob-icon{
  display:flex;align-items:center;justify-content:center;
  width:36px;height:36px;border-radius:var(--radius-md);
  color:var(--color-text-muted);
  text-decoration:none;
  transition:color .2s,background .2s;
}
.mob-icon:hover{color:var(--color-primary);background:var(--color-surface-sunken)}
.mob-call{
  display:flex;align-items:center;gap:.35rem;
  padding:.35rem .75rem;border-radius:.6rem;
  background:var(--color-accent);color:#fff;
  text-decoration:none;font-weight:700;
  transition:all .25s ease;
}
.mob-call:hover{background:var(--color-accent-dark)}
.mob-call-num{font-size:.78rem;font-weight:700}

@media(max-width:768px){
  .desktop-actions{display:none}
  .mobile-actions{display:flex}
}
/* Hide phone number text on very small screens */
@media(max-width:380px){.mob-call-num{display:none}}
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const header = document.getElementById('site-header');
    function upd() {
      header?.classList.toggle('scrolled', window.scrollY > 10);
    }
    upd();
    window.addEventListener('scroll', upd, { passive: true });
  });
</script>
