---
/**
 * ValuesList — Enhanced · coloured accent borders · compound icons · hover lift
 */
const values = [
  {
    title: "Clinical Excellence",
    description: "We maintain the highest standards in dental care, using proven techniques and premium materials for results that last a lifetime.",
    icon: "award",
    color: "#2CABDF",
    colorLight: "#E0F5FF",
    stat: "35+", statLabel: "Years of Practice",
  },
  {
    title: "Patient Comfort",
    description: "Your comfort is our priority. We create a calm, welcoming environment and offer gentle options specifically for anxious patients.",
    icon: "heart",
    color: "#EF4444",
    colorLight: "#FEF2F2",
    stat: "0", statLabel: "Judgment. Ever.",
  },
  {
    title: "Advanced Technology",
    description: "From digital X-rays to CEREC same-day crowns and 3D CT scanning — we invest in technology that produces better outcomes.",
    icon: "zap",
    color: "#F59E0B",
    colorLight: "#FFFBEB",
    stat: "CEREC", statLabel: "Same-Day Crowns",
  },
  {
    title: "Community Trust",
    description: "Three generations of Queens families have trusted us with their smiles. That legacy shapes how we approach every single visit.",
    icon: "users",
    color: "#10B981",
    colorLight: "#E8F5E9",
    stat: "10k+", statLabel: "Happy Patients",
  },
];

const icons: Record<string, { d1: string; d2?: string }> = {
  award: {
    d1: "M12 15a7 7 0 100-14 7 7 0 000 14z",
    d2: "M8.21 13.89L7 23l5-3 5 3-1.21-9.11M9 12l2 2 4-4",
  },
  heart: {
    d1: "M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z",
  },
  zap: {
    d1: "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
  },
  users: {
    d1: "M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8z",
    d2: "M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75",
  },
};
---

<section class="vals section" aria-labelledby="vals-heading">
  <div class="vals-wrap">

    <header class="vals-hdr">
      <span class="vals-eye">Our Values</span>
      <h2 id="vals-heading" class="vals-h2">The Principles That Guide Everything We Do</h2>
      <p class="vals-sub">What you can expect every single time you walk through our door.</p>
    </header>

    <div class="vals-grid">
      {values.map((v) => (
        <article class="val-card" style={`--vc:${v.color};--vcl:${v.colorLight}`}>
          <div class="val-top">
            <div class="val-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true">
                <path d={icons[v.icon].d1}/>
                {icons[v.icon].d2 && <path d={icons[v.icon].d2}/>}
              </svg>
            </div>
            <div class="val-stat">
              <span class="val-stat-num">{v.stat}</span>
              <span class="val-stat-lbl">{v.statLabel}</span>
            </div>
          </div>
          <h3 class="val-title">{v.title}</h3>
          <p class="val-desc">{v.description}</p>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
.vals { background: var(--color-surface) }
.vals-wrap {
  max-width: var(--container-xl); margin-inline: auto;
  padding-inline: clamp(.75rem,3vw,var(--spacing-element));
}
.vals-hdr { text-align: center; max-width: 580px; margin-inline: auto; margin-bottom: clamp(2rem,4vw,3.5rem) }
.vals-eye {
  display: inline-block; font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  color: var(--color-secondary-dark); background: rgba(61,186,167,.1);
  border-radius: 9999px; padding: .25rem .875rem; margin-bottom: .875rem;
}
.vals-h2 {
  font-size: clamp(1.75rem,3.5vw,2.5rem); font-family: var(--font-family-heading);
  font-weight: 700; color: var(--color-primary); letter-spacing: -.025em; line-height: 1.15; margin: 0 0 1rem;
}
.vals-sub { font-size: var(--font-size-lg); color: var(--color-text-muted); line-height: 1.65; margin: 0 }

.vals-grid {
  display: grid; grid-template-columns: 1fr; gap: 1.125rem;
}
@media(min-width:640px){ .vals-grid { grid-template-columns: repeat(2,1fr) } }
@media(min-width:1024px){ .vals-grid { grid-template-columns: repeat(4,1fr); gap: 1.25rem } }

.val-card {
  padding: 1.625rem;
  background: #fff;
  border-radius: 1.125rem;
  border: 1.5px solid var(--color-border);
  border-left: 4px solid var(--vc);
  transition: all .3s ease;
  display: flex; flex-direction: column; gap: .875rem;
}
.val-card:hover {
  box-shadow: 0 12px 36px rgba(16,43,63,.09);
  transform: translateY(-3px);
  border-color: var(--vc);
  background: linear-gradient(160deg, var(--vcl) 0%, #fff 50%);
}
.val-top { display: flex; justify-content: space-between; align-items: flex-start }
.val-icon {
  width: 2.75rem; height: 2.75rem; border-radius: .75rem;
  background: var(--vcl); color: var(--vc);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  transition: all .3s ease;
}
.val-card:hover .val-icon { background: var(--vc); color: #fff }
.val-stat { text-align: right }
.val-stat-num {
  display: block; font-size: 1.25rem; font-family: var(--font-family-heading);
  font-weight: 800; color: var(--vc); letter-spacing: -.02em; line-height: 1;
}
.val-stat-lbl { display: block; font-size: .62rem; color: var(--color-text-muted); font-weight: 500; margin-top: .15rem }
.val-title {
  font-size: var(--font-size-lg); font-family: var(--font-family-heading);
  font-weight: 700; color: var(--color-primary); line-height: 1.3; margin: 0;
}
.val-desc { font-size: var(--font-size-sm); color: var(--color-text-muted); line-height: 1.75; margin: 0; flex: 1 }
@media(prefers-reduced-motion:reduce){ .val-card { transition: none; transform: none } }
</style>
