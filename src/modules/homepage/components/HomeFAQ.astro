---
/**
 * HomeFAQ — enhanced with dot-grid background, smooth animation, Schema.org
 */
const faqItems = [
  {
    question: "How often should I visit the dentist?",
    answer: "We recommend visiting every 6 months for routine checkups and professional cleanings. Some patients with specific oral health concerns may benefit from more frequent visits — our team will guide you during your first appointment.",
    icon: "calendar",
  },
  {
    question: "Do you accept my dental insurance?",
    answer: "Yes — we accept most major dental insurance plans including Delta Dental, Cigna, Aetna, MetLife, Guardian, and United Healthcare. Call us on (718) 956-8400 or visit our Financial Information page to verify your specific coverage.",
    icon: "shield",
  },
  {
    question: "What should I expect during my first visit?",
    answer: "Your first visit includes a comprehensive exam, digital X-rays, and a professional cleaning. We'll discuss your dental history, address any concerns, and create a personalised treatment plan tailored to your needs and goals.",
    icon: "star",
  },
  {
    question: "What is CEREC same-day crown technology?",
    answer: "CEREC uses 3D digital scanning and in-office milling to design and create a custom porcelain crown in a single appointment — no temporaries, no second visit. Most crowns are ready within 90 minutes.",
    icon: "zap",
  },
  {
    question: "What can I do about dental anxiety?",
    answer: "Dental anxiety is extremely common, and our entire team is trained to help. We use a gentle approach, take time to explain every step, and can accommodate various comfort needs. Please let us know before your appointment so we can prepare.",
    icon: "heart",
  },
  {
    question: "Do you offer emergency dental services?",
    answer: "Absolutely. We offer same-day emergency appointments for urgent issues like severe toothaches, broken or knocked-out teeth, or dental trauma. Call us immediately at (718) 956-8400 and we will do our best to see you the same day.",
    icon: "alert",
  },
];

const iconPaths: Record<string, string> = {
  calendar: "M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  star: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
  zap: "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
  heart: "M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z",
  alert: "M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01",
};

const schemaData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {"@type": "Answer","text": item.answer},
  })),
};
---

<section class="faq section" aria-labelledby="faq-heading">
  <div class="faq-inner">

    <header class="faq-header">
      <span class="faq-eyebrow">Got Questions?</span>
      <h2 id="faq-heading" class="faq-title">Frequently Asked Questions</h2>
      <p class="faq-subtitle">
        Quick answers to the questions our patients ask most often.
      </p>
    </header>

    <div class="faq-grid">
      {faqItems.map((item) => (
        <details class="faq-item" name="faq-accord">
          <summary class="faq-q">
            <span class="faq-q-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths[item.icon]}/>
              </svg>
            </span>
            <span class="faq-q-text">{item.question}</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </summary>
          <div class="faq-a">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq-footer">
      <p class="faq-footer-text">Still have questions?</p>
      <div class="faq-footer-ctas">
        <a href="/contact" class="faq-cta-primary">Contact Us</a>
        <a href="tel:+17189568400" class="faq-cta-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          (718) 956-8400
        </a>
      </div>
    </div>

  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

<style>
.faq{
  background:var(--color-surface);
  position:relative;
  overflow:hidden;
}
.faq::before{
  content:'';
  position:absolute;
  inset:0;
  background-image:radial-gradient(circle,rgba(16,43,63,.06) 1px,transparent 1px);
  background-size:28px 28px;
  pointer-events:none;
}

.faq-inner{
  max-width:var(--container-xl);
  margin-inline:auto;
  padding-inline:var(--spacing-element);
  position:relative;
}
@media(max-width:639px){.faq-inner{padding-inline:.75rem}}

.faq-header{text-align:center;max-width:560px;margin-inline:auto;margin-bottom:clamp(2rem,3vw,3rem)}
.faq-eyebrow{display:inline-block;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--color-secondary-dark);margin-bottom:.75rem;padding:.25rem .875rem;background:rgba(61,186,167,.1);border-radius:9999px}
.faq-title{font-size:clamp(1.75rem,3.5vw,2.5rem);font-family:var(--font-family-heading);font-weight:700;color:var(--color-primary);letter-spacing:-.02em;margin:0 0 1rem;line-height:1.15}
.faq-subtitle{font-size:var(--font-size-lg);color:var(--color-text-muted);line-height:1.65;margin:0}

.faq-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:.75rem;
  max-width:860px;
  margin-inline:auto;
}
@media(min-width:768px){
  .faq-grid{
    grid-template-columns:repeat(2,1fr);
    align-items:start;
  }
}

.faq-item{
  background:#fff;
  border:1.5px solid var(--color-border);
  border-radius:1rem;
  overflow:hidden;
  transition:border-color .25s ease,box-shadow .25s ease;
}
.faq-item:hover{border-color:var(--color-border-strong)}
.faq-item[open]{border-color:var(--color-secondary);box-shadow:0 4px 20px rgba(61,186,167,.12)}

.faq-q{
  display:flex;
  align-items:center;
  gap:.875rem;
  padding:1.25rem 1.25rem;
  cursor:pointer;
  list-style:none;
  font-weight:600;
  font-size:var(--font-size-base);
  color:var(--color-text);
  transition:background .2s ease;
  user-select:none;
}
.faq-q::-webkit-details-marker{display:none}
.faq-q:hover{background:var(--color-surface)}
.faq-item[open] .faq-q{background:rgba(61,186,167,.06)}

.faq-q-icon{
  width:2rem;height:2rem;
  border-radius:.5rem;
  background:rgba(61,186,167,.1);
  color:var(--color-secondary-dark);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  transition:all .2s ease;
}
.faq-item[open] .faq-q-icon{background:var(--color-secondary);color:#fff}

.faq-q-text{flex:1;line-height:1.4}

.faq-chevron{
  display:flex;align-items:center;justify-content:center;
  width:1.75rem;height:1.75rem;
  border-radius:.5rem;
  background:var(--color-surface);
  color:var(--color-text-muted);
  flex-shrink:0;
  transition:transform .3s ease,background .2s ease;
}
.faq-item[open] .faq-chevron{
  transform:rotate(180deg);
  background:var(--color-secondary);
  color:#fff;
}

.faq-a{
  padding:.25rem 1.25rem 1.25rem calc(1.25rem + 2rem + .875rem);
  color:var(--color-text-muted);
  line-height:1.75;
  font-size:var(--font-size-sm);
}
.faq-a p{margin:0}

.faq-footer{
  text-align:center;
  margin-top:clamp(2rem,3vw,3rem);
}
.faq-footer-text{
  font-size:var(--font-size-base);
  color:var(--color-text-muted);
  margin:0 0 1rem;
}
.faq-footer-ctas{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:1rem;
  flex-wrap:wrap;
}
.faq-cta-primary{
  display:inline-flex;align-items:center;
  padding:.75rem 1.5rem;
  border-radius:.75rem;
  background:var(--color-primary);
  color:#fff;
  font-weight:600;
  font-size:var(--font-size-sm);
  text-decoration:none;
  transition:all .25s ease;
}
.faq-cta-primary:hover{background:var(--color-primary-dark);transform:translateY(-1px)}
.faq-cta-secondary{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.75rem 1.25rem;
  border-radius:.75rem;
  border:1.5px solid var(--color-border);
  color:var(--color-primary);
  font-weight:600;
  font-size:var(--font-size-sm);
  text-decoration:none;
  transition:all .25s ease;
}
.faq-cta-secondary:hover{border-color:var(--color-primary);background:var(--color-surface)}

@media(prefers-reduced-motion:no-preference){
  .faq-a{
    animation:faq-slide .25s ease-out;
  }
  @keyframes faq-slide{
    from{opacity:0;transform:translateY(-6px)}
    to{opacity:1;transform:translateY(0)}
  }
}
</style>
