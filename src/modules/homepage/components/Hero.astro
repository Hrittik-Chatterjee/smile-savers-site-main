---
/**
 * Hero - Enhanced — crisp, conversion-first, all breakpoints
 */
import { siteConfig } from "@/config/site";
---

<section class="hero" aria-labelledby="hero-heading">

  <div class="hero-bg" aria-hidden="true">
    <img
      src="/images/hero-dental-office.jpg"
      alt=""
      class="hero-bg-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
    <div class="hero-glow"></div>
    <div class="hero-grid-texture" aria-hidden="true"></div>
  </div>

  <div class="hero-body">

    <div class="hero-pill" role="status">
      <span class="pill-dot" aria-hidden="true"></span>
      <span>Accepting New Patients &mdash; No Referral Needed</span>
    </div>

    <h1 id="hero-heading" class="hero-h1">
      Top-Rated Dental Care<br/>
      <span class="hero-h1-accent">
        in Woodside, NYC
        <svg class="hero-underline" viewBox="0 0 260 12" preserveAspectRatio="none" aria-hidden="true">
          <path d="M2 8 Q65 2 130 6 Q195 10 258 4" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
        </svg>
      </span>
    </h1>

    <p class="hero-sub">
      Compassionate, pain-free dentistry from our expert team of three specialist dentists.
      <strong class="hero-sub-em">Same-day emergency appointments available.</strong>
    </p>

    <div class="hero-ctas">
      <a href="tel:+17189568400" class="cta-primary">
        <span>Call Now</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href={`tel:${siteConfig.phone.replace(/[^0-9+]/g,'')}`} class="cta-secondary">
        <svg class="phone-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{siteConfig.phone}</span>
      </a>
    </div>

    <div class="hero-trust" aria-label="Trust indicators">
      <a href="https://share.google/Giw216ZBKaD1h2nrM" target="_blank" rel="noopener noreferrer" class="trust-chip trust-chip--link" aria-label="Read our Google reviews — 5.0 stars">
        <span class="chip-icon chip-google" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        </span>
        <div class="chip-text"><span class="chip-label">Google</span><span class="chip-value">5.0 ★ Rating</span></div>
      </a>
      <div class="trust-chip-sep" aria-hidden="true"></div>
      <div class="trust-chip">
        <span class="chip-icon chip-zocdoc" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg></span>
        <div class="chip-text"><span class="chip-label">Zocdoc</span><span class="chip-value">Top Rated</span></div>
      </div>
      <div class="trust-chip-sep trust-hide-sm" aria-hidden="true"></div>
      <div class="trust-chip trust-hide-sm">
        <span class="chip-icon chip-icoi" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
        <div class="chip-text"><span class="chip-label">ICOI</span><span class="chip-value">Board Certified</span></div>
      </div>
    </div>

  </div>

  <div class="stats-ribbon-wrap">
    <div class="stats-ribbon">
      <div class="stat-item">
        <div class="stat-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
        <div class="stat-body"><span class="stat-num">35+</span><span class="stat-lbl">Years in Queens</span></div>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item">
        <div class="stat-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
        <div class="stat-body"><span class="stat-num">10,000+</span><span class="stat-lbl">Happy Patients</span></div>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item">
        <div class="stat-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
        <div class="stat-body"><span class="stat-num stat-accent">Same‑Day</span><span class="stat-lbl">Emergency Slots</span></div>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item">
        <div class="stat-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <div class="stat-body"><span class="stat-num">3</span><span class="stat-lbl">Expert Dentists</span></div>
      </div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true"><span></span></div>

</section>

<style>
@keyframes phone-ring{0%,100%,50%{transform:rotate(0)}10%{transform:rotate(14deg)}20%{transform:rotate(-12deg)}30%{transform:rotate(8deg)}40%{transform:rotate(-4deg)}}
@keyframes glow-pulse{0%,100%{opacity:.12;transform:scale(1)}50%{opacity:.22;transform:scale(1.12)}}
@keyframes dot-pulse{0%,100%{opacity:1}50%{opacity:.35}}
@keyframes scroll-bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(8px)}}
@keyframes fade-up{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

.phone-icon{animation:phone-ring 4s ease-in-out 2s 2;transform-origin:center}
@media(prefers-reduced-motion:reduce){.phone-icon,.hero-glow,.pill-dot{animation:none}.hero-pill,.hero-h1,.hero-sub,.hero-ctas,.hero-trust{animation:none}}

.hero{position:relative;min-height:100svh;min-height:780px;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;overflow:hidden}

.hero-bg{position:absolute;inset:0;z-index:0}
.hero-bg-img{width:100%;height:100%;object-fit:cover;object-position:center 20%}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(105deg,rgba(10,29,43,.94) 0%,rgba(10,29,43,.82) 42%,rgba(10,29,43,.45) 72%,rgba(10,29,43,.12) 100%)}
.hero-glow{position:absolute;top:15%;left:58%;width:38rem;height:38rem;background:radial-gradient(circle,var(--color-secondary) 0%,transparent 70%);opacity:.12;filter:blur(60px);animation:glow-pulse 6s ease-in-out infinite;pointer-events:none}
.hero-grid-texture{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:48px 48px;mask-image:linear-gradient(to right,transparent 0%,black 25%,black 65%,transparent 100%);-webkit-mask-image:linear-gradient(to right,transparent 0%,black 25%,black 65%,transparent 100%)}

.hero-body{position:relative;z-index:10;width:100%;max-width:80rem;margin:0 auto;padding:2rem 1rem 22rem 1.25rem;display:flex;flex-direction:column;align-items:flex-start}
@media(min-width:640px){.hero-body{padding:2rem 2rem 18rem 2rem}}
@media(min-width:768px){.hero-body{padding:2rem 2rem 14rem 3rem}}
@media(min-width:1024px){.hero-body{padding:2rem 2rem 12rem 4rem}}

.hero-pill{display:inline-flex;align-items:center;gap:.5rem;padding:.35rem 1rem;border-radius:9999px;background:rgba(61,186,167,.15);border:1px solid rgba(61,186,167,.35);color:#a8e0d6;font-size:.7rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;margin-bottom:1.25rem;animation:fade-up .5s ease-out both;backdrop-filter:blur(8px)}
.pill-dot{width:.5rem;height:.5rem;border-radius:50%;background:var(--color-secondary);flex-shrink:0;animation:dot-pulse 2s ease-in-out infinite}

.hero-h1{font-size:clamp(2.2rem,5.5vw,4.75rem);font-family:var(--font-family-heading);font-weight:700;color:#fff;line-height:1.08;margin:0 0 1.5rem;letter-spacing:-.025em;text-shadow:0 2px 20px rgba(0,0,0,.2);animation:fade-up .6s ease-out .1s both}
.hero-h1-accent{display:block;color:var(--color-secondary);position:relative;width:max-content}
.hero-underline{position:absolute;width:100%;height:.2em;bottom:-.15em;left:0;color:var(--color-secondary);opacity:.5;overflow:visible}

.hero-sub{font-size:clamp(.95rem,1.8vw,1.18rem);color:rgba(255,255,255,.72);line-height:1.68;margin:0 0 2.25rem;max-width:38rem;font-weight:300;animation:fade-up .6s ease-out .2s both}
.hero-sub-em{display:block;color:#fff;font-weight:600;margin-top:.25rem}
@media(min-width:768px){.hero-sub-em{display:inline;margin-top:0}}

.hero-ctas{display:flex;flex-direction:column;gap:.75rem;width:100%;margin-bottom:2rem;animation:fade-up .6s ease-out .3s both}
@media(min-width:480px){.hero-ctas{flex-direction:row;width:auto;gap:1rem}}

.cta-primary{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.9rem 1.75rem;border-radius:.75rem;background:var(--color-accent);color:#fff;font-weight:700;font-size:1rem;text-decoration:none;box-shadow:0 8px 28px rgba(44,171,223,.42);transition:all .25s ease;white-space:nowrap}
.cta-primary:hover{background:var(--color-accent-dark);transform:translateY(-2px);box-shadow:0 14px 38px rgba(44,171,223,.55)}
.cta-primary svg{transition:transform .25s ease}
.cta-primary:hover svg{transform:translateX(4px)}

.cta-secondary{display:inline-flex;align-items:center;justify-content:center;gap:.6rem;padding:.875rem 1.5rem;border-radius:.75rem;background:rgba(255,255,255,.1);color:#fff;font-weight:600;font-size:1rem;text-decoration:none;border:1.5px solid rgba(255,255,255,.3);backdrop-filter:blur(10px);transition:all .25s ease;white-space:nowrap}
.cta-secondary:hover{background:rgba(255,255,255,.2);border-color:rgba(255,255,255,.5)}

.hero-trust{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;animation:fade-up .6s ease-out .4s both}
@media(min-width:640px){.hero-trust{flex-wrap:nowrap}}
.trust-chip{display:flex;align-items:center;gap:.5rem;padding:.45rem .875rem;background:rgba(255,255,255,.08);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.12);border-radius:.6rem}
.trust-chip--link{text-decoration:none;transition:background .2s,border-color .2s}
.trust-chip--link:hover{background:rgba(255,255,255,.16);border-color:rgba(255,255,255,.28)}
.trust-chip-sep{width:1px;height:2rem;background:rgba(255,255,255,.15);display:none}
@media(min-width:480px){.trust-chip-sep{display:block}}
/* Hide ICOI chip on very small screens to prevent wrapping */
@media(max-width:479px){.trust-hide-sm{display:none!important}}
.chip-icon{display:flex;align-items:center;justify-content:center;width:1.75rem;height:1.75rem;border-radius:.4rem;flex-shrink:0}
.chip-google{background:#fff}
.chip-zocdoc{background:#00B5AD;color:#fff}
.chip-icoi{background:var(--color-accent);color:#fff}
.chip-text{display:flex;flex-direction:column;line-height:1.1}
.chip-label{font-size:.6rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.05em}
.chip-value{font-size:.78rem;font-weight:700;color:#fff}

.stats-ribbon-wrap{position:absolute;bottom:0;left:0;right:0;z-index:20;padding:0 .75rem}
@media(min-width:640px){.stats-ribbon-wrap{padding:0 1.5rem}}
@media(min-width:768px){.stats-ribbon-wrap{padding:0 2rem}}

.stats-ribbon{max-width:76rem;margin:0 auto;background:rgba(255,255,255,.97);backdrop-filter:blur(24px);border-radius:1.25rem 1.25rem 0 0;padding:1.25rem 1rem;box-shadow:0 -4px 40px rgba(16,43,63,.12);display:grid;grid-template-columns:1fr 1fr;gap:1rem .75rem;border-top:2.5px solid var(--color-secondary)}
@media(min-width:600px){.stats-ribbon{grid-template-columns:repeat(4,1fr);gap:0}}
@media(min-width:768px){.stats-ribbon{border-radius:9999px 9999px 0 0;padding:1.4rem 2.5rem}}

.stat-item{display:flex;align-items:center;gap:.875rem}
@media(min-width:768px){.stat-item{justify-content:center;padding:0 1.5rem}}
.stat-sep{display:none}
@media(min-width:768px){.stat-sep{display:block;width:1px;height:2.5rem;background:var(--color-border);align-self:center}}
.stat-icon-wrap{width:2.75rem;height:2.75rem;border-radius:50%;background:#EFF6EE;display:flex;align-items:center;justify-content:center;color:var(--color-primary);flex-shrink:0}
.stat-icon-wrap svg{width:1.4rem;height:1.4rem}
.stat-body{display:flex;flex-direction:column;line-height:1.2}
.stat-num{font-size:clamp(1.3rem,2.5vw,1.75rem);font-family:var(--font-family-heading);font-weight:800;color:var(--color-primary);letter-spacing:-.02em}
.stat-accent{color:var(--color-accent)}
.stat-lbl{font-size:.7rem;color:var(--color-text-muted);font-weight:500;white-space:nowrap}

.scroll-hint{position:absolute;bottom:10rem;left:50%;transform:translateX(-50%);z-index:15;display:none}
@media(min-width:1024px){.scroll-hint{display:flex;bottom:11.5rem}}
.scroll-hint span{display:block;width:1.5px;height:3rem;background:linear-gradient(to bottom,rgba(255,255,255,.6),transparent);animation:scroll-bounce 2s ease-in-out infinite}
</style>
