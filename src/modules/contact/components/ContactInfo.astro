---
/**
 * ContactInfo — Enhanced · phone as hero CTA · Google Maps link · social links
 */
---

<div class="ci">
  <h3 class="ci-title">Get In Touch</h3>
  <p class="ci-intro">
    Our friendly team is ready to help. Call us, email, or pop in during office hours.
  </p>

  <!-- Phone — primary hero element -->
  <a href="tel:+17189568400" class="ci-phone">
    <span class="ci-phone-icon">
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path
          d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
        ></path></svg
      >
    </span>
    <div>
      <span class="ci-phone-label">Call Us Now</span>
      <span class="ci-phone-num">(718) 956-8400</span>
    </div>
  </a>

  <!-- Info items -->
  <ul class="ci-list">
    <li class="ci-item">
      <span class="ci-icon" style="--ic:#3DBAA7">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
          ></path><polyline points="22,6 12,13 2,6"></polyline></svg
        >
      </span>
      <div>
        <span class="ci-lbl">Email</span>
        <a href="mailto:dentalsmilesavers@gmail.com" class="ci-val ci-link"
          >dentalsmilesavers@gmail.com</a
        >
      </div>
    </li>
    <li class="ci-item">
      <span class="ci-icon" style="--ic:#2CABDF">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle
            cx="12"
            cy="10"
            r="3"></circle></svg
        >
      </span>
      <div>
        <span class="ci-lbl">Address</span>
        <a
          href="https://maps.google.com/?q=3202+53rd+Pl,+Woodside,+NY+11377"
          target="_blank"
          rel="noopener noreferrer"
          class="ci-val ci-link"
        >
          3202 53rd Place<br />Woodside, NY 11377
        </a>
      </div>
    </li>
    <li class="ci-item">
      <span class="ci-icon" style="--ic:#F59E0B">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><rect x="3" y="4" width="18" height="18" rx="2"></rect><line
            x1="16"
            y1="2"
            x2="16"
            y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
            x1="3"
            y1="10"
            x2="21"
            y2="10"></line></svg
        >
      </span>
      <div>
        <span class="ci-lbl">Hours</span>
        <span class="ci-val">Mon–Thu 10AM–6PM · Fri & Sat 9AM–1PM</span>
      </div>
    </li>
  </ul>

  <!-- Emergency callout -->
  <div class="ci-emergency">
    <span class="ci-emg-dot" aria-hidden="true"></span>
    <div>
      <strong class="ci-emg-title">Dental Emergency?</strong>
      <p class="ci-emg-desc">
        Call us immediately — we offer same-day emergency slots when available.
      </p>
    </div>
  </div>
</div>

<style>
  @keyframes emg-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }
  .ci {
    padding: 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .ci-title {
    font-size: var(--font-size-2xl);
    font-family: var(--font-family-heading);
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
  }
  .ci-intro {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* Phone hero */
  .ci-phone {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: #fff;
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(16, 43, 63, 0.25);
  }
  .ci-phone:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(16, 43, 63, 0.35);
  }
  .ci-phone-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    background: rgba(61, 186, 167, 0.2);
    color: var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ci-phone-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }
  .ci-phone-num {
    display: block;
    font-size: 1.35rem;
    font-family: var(--font-family-heading);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
  }

  /* Info list */
  .ci-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ci-item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }
  .ci-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--ic) 12%, transparent);
    color: var(--ic);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ci-lbl {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.2rem;
  }
  .ci-val {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.5;
  }
  .ci-link {
    text-decoration: none;
    color: var(--color-primary);
    transition: color 0.2s;
  }
  .ci-link:hover {
    color: var(--color-secondary-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Emergency */
  .ci-emergency {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    background: #fef2f2;
    border: 1.5px solid #fecaca;
    border-radius: 0.875rem;
    padding: 1rem 1.125rem;
    margin-top: auto;
  }
  .ci-emg-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #ef4444;
    flex-shrink: 0;
    margin-top: 0.3rem;
    animation: emg-pulse 2s ease-in-out infinite;
  }
  .ci-emg-title {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: #991b1b;
    margin-bottom: 0.25rem;
  }
  .ci-emg-desc {
    font-size: 0.78rem;
    color: #b91c1c;
    line-height: 1.5;
    margin: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .ci-emg-dot {
      animation: none;
    }
  }
</style>
