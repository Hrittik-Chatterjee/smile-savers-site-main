---
/**
 * ContactForm — Enhanced · premium inputs · focus states · validation hints
 */
import { getCollection } from "astro:content";
const services = await getCollection("services");
const sortedServices = services.sort((a, b) => a.data.order - b.data.order);
---

<div class="cf">
  <div class="cf-head">
    <h3 class="cf-title">Send Us a Message</h3>
    <p class="cf-sub">We respond to every message within 24 hours — usually much faster.</p>
  </div>

  <div id="form-status" class="cf-status" role="status" aria-live="polite"></div>

  <form class="cf-form" method="POST" action="/api/contact" id="contact-form" novalidate>

    <div class="cf-group">
      <label for="name" class="cf-label">
        Full Name <span class="cf-req" aria-hidden="true">*</span>
      </label>
      <div class="cf-input-wrap">
        <svg class="cf-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <input type="text" id="name" name="name" required autocomplete="name"
          placeholder="Dr. / Mr. / Ms. Your Name" class="cf-input" aria-describedby="name-error" />
        <svg class="cf-valid-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <span id="name-error" class="cf-error" role="alert"></span>
    </div>

    <div class="cf-row">
      <div class="cf-group">
        <label for="email" class="cf-label">
          Email <span class="cf-req" aria-hidden="true">*</span>
        </label>
        <div class="cf-input-wrap">
          <svg class="cf-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <input type="email" id="email" name="email" required autocomplete="email"
            placeholder="you@example.com" class="cf-input" aria-describedby="email-error" />
          <svg class="cf-valid-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span id="email-error" class="cf-error" role="alert"></span>
      </div>
      <div class="cf-group">
        <label for="phone" class="cf-label">Phone</label>
        <div class="cf-input-wrap">
          <svg class="cf-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <input type="tel" id="phone" name="phone" autocomplete="tel"
            placeholder="(718) 555-0123" class="cf-input" />
        </div>
      </div>
    </div>

    <div class="cf-group">
      <label for="service" class="cf-label">Service Interest</label>
      <div class="cf-select-wrap">
        <svg class="cf-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <select id="service" name="service" class="cf-select">
          <option value="">Select a service (optional)</option>
          {sortedServices.map((s) => (
            <option value={s.data.slug}>{s.data.title}</option>
          ))}
          <option value="other">Other / Not Sure</option>
        </select>
        <svg class="cf-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>

    <div class="cf-group">
      <label for="message" class="cf-label">
        Message <span class="cf-req" aria-hidden="true">*</span>
      </label>
      <textarea id="message" name="message" required rows="4" class="cf-textarea"
        placeholder="Tell us how we can help — any symptoms, questions, or preferred times…"
        aria-describedby="message-error"></textarea>
      <span id="message-error" class="cf-error" role="alert"></span>
    </div>

    <div class="cf-check-group">
      <label class="cf-check-label">
        <input type="checkbox" name="newPatient" value="yes" class="cf-check" />
        <span class="cf-check-box" aria-hidden="true"></span>
        I am a new patient
      </label>
      <label class="cf-check-label">
        <input type="checkbox" name="urgency" value="urgent" class="cf-check" />
        <span class="cf-check-box" aria-hidden="true"></span>
        This is urgent / dental emergency
      </label>
    </div>

    <button type="submit" class="cf-submit" id="submit-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      Send Message
    </button>

    <p class="cf-privacy">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Your information is private and never shared.
    </p>

  </form>
</div>

<style>
.cf { padding: 2rem; height: 100%; display: flex; flex-direction: column; gap: 1.5rem }
.cf-head {}
.cf-title { font-size: var(--font-size-2xl); font-family: var(--font-family-heading); font-weight: 700; color: var(--color-primary); margin: 0 0 .375rem }
.cf-sub { font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0; line-height: 1.6 }

.cf-status { display: none; padding: .875rem 1rem; border-radius: .75rem; font-size: var(--font-size-sm); font-weight: 600 }
.cf-status.success { display: block; background: #E8F5E9; color: #2E7D32; border: 1px solid #A5D6A7 }
.cf-status.error { display: block; background: #FFEBEE; color: #C62828; border: 1px solid #FFCDD2 }

.cf-form { display: flex; flex-direction: column; gap: 1.125rem }
.cf-row { display: grid; grid-template-columns: 1fr; gap: 1.125rem }
@media(min-width:540px){ .cf-row { grid-template-columns: 1fr 1fr } }

.cf-group { display: flex; flex-direction: column; gap: .375rem }
.cf-label { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text) }
.cf-req { color: var(--color-error); margin-left: .1rem }

/* Input wrapper */
.cf-input-wrap, .cf-select-wrap {
  position: relative; display: flex; align-items: center;
}
.cf-input-icon {
  position: absolute; left: .875rem;
  color: var(--color-text-muted); pointer-events: none; flex-shrink: 0;
}

/* Inputs */
.cf-input, .cf-select, .cf-textarea {
  width: 100%; padding: .75rem 1rem;
  background: var(--color-surface-elevated);
  border: 1.5px solid var(--color-border);
  border-radius: .75rem;
  font-size: var(--font-size-sm); color: var(--color-text);
  font-family: inherit; line-height: 1.5;
  transition: border-color .2s ease, box-shadow .2s ease;
  box-sizing: border-box;
}
.cf-input, .cf-select { padding-left: 2.625rem }
.cf-input::placeholder, .cf-textarea::placeholder { color: var(--color-text-muted); opacity: .6 }
.cf-input:focus, .cf-select:focus, .cf-textarea:focus {
  outline: none;
  border-color: var(--color-accent);
  box-shadow: 0 0 0 3px rgba(44,171,223,.15);
  background: #fff;
}
.cf-input:invalid:not(:placeholder-shown) { border-color: var(--color-error) }
.cf-input:valid:not(:placeholder-shown) { border-color: var(--color-success) }

/* Validation state icon (right side of input) */
.cf-valid-icon {
  position: absolute;
  right: .875rem;
  display: none;
  pointer-events: none;
  animation: cf-pop .2s ease;
  flex-shrink: 0;
}
@keyframes cf-pop {
  from { transform: scale(0); opacity: 0 }
  to   { transform: scale(1); opacity: 1 }
}
.cf-input:valid:not(:placeholder-shown) ~ .cf-valid-icon { display: flex; color: var(--color-success) }
.cf-input:invalid:not(:placeholder-shown) ~ .cf-valid-icon { display: flex; color: var(--color-error) }

/* Select */
.cf-select-wrap { position: relative }
.cf-select { padding-right: 2.5rem; appearance: none; cursor: pointer }
.cf-select-arrow { position: absolute; right: .875rem; color: var(--color-text-muted); pointer-events: none }

/* Textarea */
.cf-textarea { resize: vertical; min-height: 110px; padding: .75rem 1rem }

/* Error */
.cf-error { font-size: .75rem; color: var(--color-error); font-weight: 500; min-height: 1rem }

/* Checkboxes */
.cf-check-group { display: flex; flex-direction: column; gap: .625rem }
.cf-check-label {
  display: flex; align-items: center; gap: .625rem;
  font-size: var(--font-size-sm); color: var(--color-text); cursor: pointer;
  user-select: none;
}
.cf-check { position: absolute; opacity: 0; width: 0; height: 0 }
.cf-check-box {
  width: 1.125rem; height: 1.125rem; border-radius: .3rem; flex-shrink: 0;
  border: 1.5px solid var(--color-border);
  background: var(--color-surface-elevated);
  transition: all .2s ease;
  display: flex; align-items: center; justify-content: center;
}
.cf-check:checked + .cf-check-box {
  background: var(--color-accent); border-color: var(--color-accent);
}
.cf-check:checked + .cf-check-box::after {
  content: '';
  display: block;
  width: .35rem; height: .6rem;
  border: 2px solid #fff; border-top: none; border-left: none;
  transform: rotate(45deg) translateY(-1px);
}
.cf-check:focus + .cf-check-box { box-shadow: 0 0 0 3px rgba(44,171,223,.2) }

/* Submit */
.cf-submit {
  display: flex; align-items: center; justify-content: center; gap: .5rem;
  width: 100%; padding: .9rem 1.5rem;
  background: var(--color-accent); color: #fff;
  border: none; border-radius: .75rem;
  font-size: var(--font-size-base); font-weight: 700; font-family: inherit;
  cursor: pointer; min-height: 48px;
  box-shadow: 0 4px 16px rgba(44,171,223,.35);
  transition: all .25s ease;
}
.cf-submit:hover { background: var(--color-accent-dark); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(44,171,223,.45) }
.cf-submit:active { transform: none; box-shadow: 0 2px 8px rgba(44,171,223,.3) }

.cf-privacy {
  display: flex; align-items: center; gap: .375rem;
  font-size: .75rem; color: var(--color-text-muted); margin: 0; text-align: center;
  justify-content: center;
}
.cf-privacy svg { color: var(--color-success); flex-shrink: 0 }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn  = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !status) return;

    // Loading state
    btn.disabled = true;
    btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite" aria-hidden="true"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> Sending…`;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();

      if (data.success) {
        status.className = 'cf-status success';
        status.textContent = '✓ Message sent! We\'ll reply within 24 hours. Check your inbox for a confirmation.';
        form.reset();
      } else {
        throw new Error(data.error || 'Unknown error');
      }
    } catch (err: any) {
      status.className = 'cf-status error';
      status.textContent = err.message?.includes('Server error')
        ? err.message
        : '✗ Something went wrong. Please call us at (718) 956-8400.';
    } finally {
      btn.disabled = false;
      btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Send Message`;
      status.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });
</script>

<style>
@keyframes spin { to { transform: rotate(360deg) } }
</style>
