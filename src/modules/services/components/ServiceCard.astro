---
/**
 * ServiceCard — Enhanced · colour-coded by category · compound icons · hover glow
 */
import type { CollectionEntry } from 'astro:content';

interface Props { service: CollectionEntry<'services'> }
const { service } = Astro.props;
const { title, shortDescription, icon, category, duration } = service.data;

/* Compound SVG paths — 2-path icons for visual weight */
const icons: Record<string, { d1: string; d2?: string }> = {
  tooth: {
    d1: 'M12 3c-2.2 0-4 2-4 4.5 0 1.8.7 3.2.9 5C9 15 8 17.8 10 19.5c1 .9 2.5.3 2.5-1v-3c0-1.1 1-2 2-2s2 .9 2 2v3c0 1.3 1.5 1.9 2.5 1 2-1.7 1-4.5 1-7 .2-1.8.9-3.2.9-5 0-2.5-1.8-4.5-4-4.5h-1z',
    d2: 'M9 9c0-1.2.9-2.5 3-2.5s3 1.3 3 2.5',
  },
  implant: {
    d1: 'M12 2v12M9 14h6M10 17h4M10.5 20h3',
    d2: 'M9 6h6M10 9h4',
  },
  crown: {
    d1: 'M4 14l2-8 3 5 3-8 3 8 3-5 2 8H4z',
    d2: 'M4 14v5a1 1 0 001 1h14a1 1 0 001-1v-5',
  },
  sparkle: {
    d1: 'M12 2l1.6 4.8L18.4 8l-4.8 1.6L12 14.4l-1.6-4.8L5.6 8l4.8-1.6z',
    d2: 'M19 15l.8 2.4 2.4.8-2.4.8L19 21.4l-.8-2.4-2.4-.8 2.4-.8z M5 1l.6 1.8 1.8.6-1.8.6L5 5.8l-.6-1.8-1.8-.6 1.8-.6z',
  },
  shield: {
    d1: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    d2: 'M9 12l2 2 4-4',
  },
  heart: {
    d1: 'M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z',
  },
};

const catMeta: Record<string, { label: string; color: string; colorLight: string }> = {
  preventive: { label: 'Preventive', color: '#10B981', colorLight: '#E8F5E9' },
  cosmetic:   { label: 'Cosmetic',   color: '#F59E0B', colorLight: '#FFFBEB' },
  restorative:{ label: 'Restorative',color: '#3B82F6', colorLight: '#EFF6FF' },
  emergency:  { label: 'Emergency',  color: '#EF4444', colorLight: '#FEF2F2' },
};

const meta = catMeta[category] ?? catMeta.preventive;
const ico = icons[icon] ?? icons.tooth;
---

<article class="svc" style={`--c:${meta.color};--cl:${meta.colorLight}`}>

  <!-- Category badge -->
  <div class="svc-cat">{meta.label}</div>

  <!-- Icon -->
  <div class="svc-icon">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
      fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      aria-hidden="true">
      <path d={ico.d1}/>
      {ico.d2 && <path d={ico.d2}/>}
    </svg>
  </div>

  <!-- Content -->
  <h3 class="svc-title">{title}</h3>
  <p class="svc-desc">{shortDescription}</p>

  {duration && (
    <p class="svc-dur">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      {duration}
    </p>
  )}

  <a href={`/services/${service.id}`} class="svc-link" aria-label={`Learn more about ${title}`}>
    Learn more
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>

</article>

<style>
.svc {
  display: flex; flex-direction: column;
  padding: 1.5rem;
  background: #fff;
  border-radius: 1.125rem;
  border: 1.5px solid var(--color-border);
  transition: all .3s ease;
  position: relative; overflow: hidden;
  /* No fixed aspect-ratio — let content breathe */
  min-height: 280px;
}
.svc::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--cl) 0%, transparent 55%);
  opacity: 0;
  transition: opacity .3s ease;
}
.svc:hover {
  border-color: var(--c);
  box-shadow: 0 12px 36px rgba(16,43,63,.1);
  transform: translateY(-3px);
}
.svc:hover::before { opacity: 1 }

@media(min-width:640px){ .svc { padding: 1.75rem } }
@media(min-width:1024px){ .svc { padding: 2rem } }

/* Category */
.svc-cat {
  position: relative;
  display: inline-block; width: fit-content;
  font-size: .62rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .07em;
  color: var(--c);
  background: var(--cl);
  border: 1px solid color-mix(in srgb, var(--c) 25%, transparent);
  padding: .2rem .6rem;
  border-radius: 9999px;
  margin-bottom: 1rem;
}

/* Icon */
.svc-icon {
  position: relative;
  width: 3rem; height: 3rem;
  border-radius: .875rem;
  background: var(--cl);
  color: var(--c);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1rem;
  flex-shrink: 0;
  transition: all .3s ease;
}
.svc:hover .svc-icon { background: var(--c); color: #fff }

@media(min-width:640px){ .svc-icon { width: 3.25rem; height: 3.25rem } }

/* Content */
.svc-title {
  position: relative;
  font-size: clamp(1rem,1.5vw,1.15rem);
  font-family: var(--font-family-heading);
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.3;
  margin: 0 0 .625rem;
}
.svc-desc {
  position: relative;
  font-size: var(--font-size-sm);
  color: var(--color-text-muted);
  line-height: 1.7;
  margin: 0 0 auto;
  padding-bottom: 1rem;
  flex-grow: 1;
}
.svc-dur {
  position: relative;
  display: flex; align-items: center; gap: .35rem;
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  margin: 0 0 .75rem;
}
.svc-link {
  position: relative;
  display: inline-flex; align-items: center; gap: .375rem;
  font-size: var(--font-size-sm); font-weight: 700;
  color: var(--c);
  text-decoration: none;
  min-height: 44px;
  transition: gap .2s ease;
  text-underline-offset: 3px;
  margin-top: auto;
}
.svc-link:hover { gap: .625rem; text-decoration: underline }

@media(prefers-reduced-motion:reduce){ .svc,.svc-icon { transition: none; transform: none } }
</style>
