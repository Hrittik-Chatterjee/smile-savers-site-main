---
/**
 * ServiceDetail — clean layout, breadcrumb/header handled by parent [slug].astro
 */
import { render, type CollectionEntry } from "astro:content";
import FAQ from "./FAQ.astro";

interface Props {
  service: CollectionEntry<"services">;
}

const { service } = Astro.props;
const { title, benefits, faq, duration, category } = service.data;
const { Content } = await render(service);

const categoryColors: Record<string, string> = {
  preventive: "#10B981",
  cosmetic:   "#F59E0B",
  restorative:"#3B82F6",
  emergency:  "#EF4444",
};
const accent = categoryColors[category] ?? "#2CABDF";
---

<article class="sd">

  <!-- Duration pill if present -->
  {duration && (
    <div class="sd-meta">
      <span class="sd-duration" style={`color:${accent};border-color:${accent}20;background:${accent}08`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        {duration}
      </span>
    </div>
  )}

  <!-- Prose content from markdown -->
  <div class="sd-prose prose">
    <Content />
  </div>

  <!-- Benefits -->
  {benefits && benefits.length > 0 && (
    <section class="sd-benefits" aria-labelledby="benefits-h">
      <h2 id="benefits-h" class="sd-benefits-title">Key Benefits</h2>
      <ul class="sd-benefits-list">
        {benefits.map((b) => (
          <li class="sd-benefit-item" style={`--ba:${accent}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="sd-check">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- FAQ -->
  {faq && faq.length > 0 && <FAQ items={faq} title={`${title} — Frequently Asked Questions`} />}

</article>

<style>
.sd { max-width: 760px; margin-inline: auto; display: flex; flex-direction: column; gap: 2.5rem }

.sd-meta { display: flex; gap: .75rem }
.sd-duration {
  display: inline-flex; align-items: center; gap: .4rem;
  font-size: .8rem; font-weight: 600;
  padding: .3rem .875rem;
  border-radius: 9999px;
  border: 1.5px solid;
}

.sd-prose { color: var(--color-text-muted); line-height: 1.8 }
.sd-prose :global(h2) { font-size: 1.5rem; font-family: var(--font-family-heading); font-weight: 700; color: var(--color-primary); margin: 2rem 0 .75rem }
.sd-prose :global(h3) { font-size: 1.15rem; font-weight: 700; color: var(--color-primary); margin: 1.5rem 0 .5rem }
.sd-prose :global(p) { margin: 0 0 1rem }
.sd-prose :global(ul) { margin: 0 0 1rem; padding-left: 1.5rem }
.sd-prose :global(li) { margin-bottom: .375rem }
.sd-prose :global(table) { width: 100%; border-collapse: collapse; font-size: .9rem; margin: 1rem 0 }
.sd-prose :global(th) { background: var(--color-surface-sunken); padding: .625rem 1rem; text-align: left; font-weight: 700; border-bottom: 2px solid var(--color-border) }
.sd-prose :global(td) { padding: .625rem 1rem; border-bottom: 1px solid var(--color-border) }

.sd-benefits { background: var(--color-surface); border-radius: 1rem; padding: 1.75rem; border: 1.5px solid var(--color-border) }
.sd-benefits-title { font-size: 1.25rem; font-family: var(--font-family-heading); font-weight: 700; color: var(--color-primary); margin: 0 0 1.25rem }
.sd-benefits-list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: .625rem }
@media(min-width:600px){ .sd-benefits-list { grid-template-columns: repeat(2, 1fr) } }
.sd-benefit-item { display: flex; align-items: flex-start; gap: .625rem; font-size: var(--font-size-sm); color: var(--color-text) }
.sd-check { color: var(--ba, #10B981); flex-shrink: 0; margin-top: .1rem }
</style>
