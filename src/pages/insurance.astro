---
import PageLayout from "../layouts/PageLayout.astro";
import PageHeader from "../components/common/PageHeader.astro";
import CTASection from "../components/common/CTASection.astro";
---

<PageLayout
  title="Dental Insurance Accepted | Smile Savers Dental"
  description="Smile Savers Dental accepts Delta Dental, Cigna, Aetna, MetLife, Guardian, United Healthcare and most major plans. Call us to verify your coverage."
>
  <main id="main-content">

    <PageHeader
      title="Insurance & Payment"
      description="We accept most major dental insurance plans and offer flexible payment options. Coverage questions? Call us — we'll verify your benefits before your visit."
      breadcrumbs={[{ label:"Home", href:"/" }, { label:"Insurance" }]}
      badge="Most Insurance Accepted"
    />

    <section class="ins-section section">
      <div class="ins-wrap">

        <!-- Accepted plans grid -->
        <div class="ins-block">
          <h2 class="ins-h2">Insurance Plans We Accept</h2>
          <p class="ins-sub">We are in-network or can bill as out-of-network for most major plans. Call us to confirm your specific coverage.</p>

          <div class="ins-grid">

            {[
              { name: "Delta Dental",          color: "#0052CC", note: "In-network" },
              { name: "Cigna",                 color: "#007585", note: "In-network" },
              { name: "Aetna",                 color: "#7B2C8A", note: "In-network" },
              { name: "MetLife",               color: "#0066A1", note: "In-network" },
              { name: "Guardian",              color: "#00704A", note: "Accepted" },
              { name: "United Healthcare",     color: "#00639A", note: "Accepted" },
              { name: "Humana",                color: "#00833E", note: "Accepted" },
              { name: "Principal",             color: "#003087", note: "Accepted" },
              { name: "Anthem",                color: "#003087", note: "Accepted" },
              { name: "Empire Blue Cross",     color: "#005EB8", note: "Accepted" },
              { name: "Medicaid / CHIP",       color: "#2E7D32", note: "Child plans" },
              { name: "Most PPO Plans",        color: "#455A64", note: "Call to verify" },
            ].map(p => (
              <div class="ins-card" style={`--ic:${p.color}`}>
                <div class="ins-card-dot" aria-hidden="true"></div>
                <div>
                  <p class="ins-card-name">{p.name}</p>
                  <span class="ins-card-note">{p.note}</span>
                </div>
              </div>
            ))}

          </div>

          <div class="ins-verify">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <p>Don't see your plan? Call <a href="tel:+17189568400">(718) 956-8400</a> — we accept many more plans and will verify your coverage at no charge before your appointment.</p>
          </div>
        </div>

        <!-- How insurance works -->
        <div class="ins-block ins-block--alt">
          <h2 class="ins-h2">How It Works at Smile Savers</h2>
          <div class="ins-steps">
            {[
              { n:"1", title:"Share your insurance card", body:"Bring your card to your first visit or give us your member ID over the phone. We handle the paperwork." },
              { n:"2", title:"We verify your benefits", body:"Our team contacts your insurer before your appointment to confirm your coverage, co-pay, and any deductibles — no surprises." },
              { n:"3", title:"Clear cost estimate upfront", body:"We provide a written treatment estimate before any work begins so you know exactly what your insurance covers and what you'll pay." },
              { n:"4", title:"We submit all claims", body:"After your visit, we submit your insurance claim directly. You pay only your portion at the time of service." },
            ].map(s => (
              <div class="ins-step">
                <div class="ins-step-num" aria-hidden="true">{s.n}</div>
                <div>
                  <h3 class="ins-step-title">{s.title}</h3>
                  <p class="ins-step-body">{s.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Payment options -->
        <div class="ins-block">
          <h2 class="ins-h2">No Insurance? No Problem.</h2>
          <p class="ins-sub">We believe everyone deserves great dental care. If you don't have insurance, we offer several options to make treatment affordable.</p>
          <div class="ins-payment-grid">
            {[
              { icon:"💳", title:"Major Credit Cards", body:"Visa, Mastercard, American Express, and Discover accepted at checkout." },
              { icon:"🏦", title:"CareCredit", body:"Interest-free financing for 6 or 12 months on qualifying treatment amounts." },
              { icon:"💰", title:"Cash / Check", body:"Discounts available for patients paying in full at time of service." },
              { icon:"📋", title:"In-House Payment Plans", body:"Flexible monthly payment arrangements available — ask our front desk for details." },
            ].map(p => (
              <div class="ins-pay-card">
                <span class="ins-pay-icon" aria-hidden="true">{p.icon}</span>
                <h3 class="ins-pay-title">{p.title}</h3>
                <p class="ins-pay-body">{p.body}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <CTASection
      title="Questions About Your Coverage?"
      description="Call us before your visit. We'll verify your insurance benefits and give you a clear cost estimate — free of charge."
      buttons={[
        { label:"Call (718) 956-8400", href:"tel:+17189568400", variant:"primary" },
        { label:"Book Appointment", href:"/appointments", variant:"outline" },
      ]}
    />

  </main>
</PageLayout>

<style>
.ins-section { background: var(--color-surface) }
.ins-wrap {
  max-width: var(--container-xl);
  margin-inline: auto;
  padding-inline: clamp(.75rem,3vw,var(--spacing-element));
  display: flex; flex-direction: column; gap: 3.5rem;
}

.ins-block { }
.ins-block--alt {
  background: var(--color-surface-elevated);
  border: 1.5px solid var(--color-border);
  border-radius: 1.25rem;
  padding: 2rem 2.25rem;
}

.ins-h2 {
  font-size: clamp(1.5rem,2.5vw,2rem);
  font-family: var(--font-family-heading);
  font-weight: 700;
  color: var(--color-primary);
  margin: 0 0 .625rem;
}
.ins-sub {
  font-size: var(--font-size-base);
  color: var(--color-text-muted);
  line-height: 1.7;
  margin: 0 0 2rem;
  max-width: 680px;
}

/* Insurance plan cards */
.ins-grid {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: .75rem;
  margin-bottom: 1.5rem;
}
@media(min-width:480px){ .ins-grid { grid-template-columns: repeat(3,1fr) } }
@media(min-width:768px){ .ins-grid { grid-template-columns: repeat(4,1fr) } }
@media(min-width:1024px){ .ins-grid { grid-template-columns: repeat(6,1fr) } }

.ins-card {
  display: flex;
  align-items: flex-start;
  gap: .625rem;
  padding: .875rem 1rem;
  background: #fff;
  border: 1.5px solid var(--color-border);
  border-radius: .875rem;
  transition: all .25s ease;
}
.ins-card:hover {
  border-color: var(--ic);
  box-shadow: 0 4px 16px rgba(0,0,0,.07);
  transform: translateY(-2px);
}
.ins-card-dot {
  width: .5rem; height: .5rem;
  border-radius: 50%;
  background: var(--ic);
  flex-shrink: 0;
  margin-top: .35rem;
}
.ins-card-name { font-size: .82rem; font-weight: 700; color: var(--color-primary); margin: 0 0 .15rem; line-height: 1.3 }
.ins-card-note { font-size: .68rem; color: var(--ic); font-weight: 600; letter-spacing: .03em }

.ins-verify {
  display: flex;
  align-items: flex-start;
  gap: .625rem;
  background: #E3F2FD;
  border: 1px solid #BBDEFB;
  border-radius: .875rem;
  padding: 1rem 1.25rem;
  font-size: var(--font-size-sm);
  color: #1565C0;
  line-height: 1.6;
}
.ins-verify svg { flex-shrink:0; margin-top:.15rem; color:#1565C0 }
.ins-verify a { color:#1565C0; font-weight:700; text-decoration:none }
.ins-verify a:hover { text-decoration:underline }
.ins-verify p { margin:0 }

/* How it works steps */
.ins-steps { display: flex; flex-direction: column; gap: 1.25rem }
.ins-step { display: flex; align-items: flex-start; gap: 1.125rem }
.ins-step-num {
  width: 2.25rem; height: 2.25rem;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: .9rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ins-step-title { font-size: var(--font-size-base); font-weight: 700; color: var(--color-primary); margin: 0 0 .3rem }
.ins-step-body { font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0; line-height: 1.65 }

/* Payment options */
.ins-payment-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media(min-width:480px){ .ins-payment-grid { grid-template-columns: repeat(2,1fr) } }
@media(min-width:1024px){ .ins-payment-grid { grid-template-columns: repeat(4,1fr) } }

.ins-pay-card {
  background: #fff;
  border: 1.5px solid var(--color-border);
  border-radius: 1rem;
  padding: 1.25rem 1.5rem;
  transition: all .25s ease;
}
.ins-pay-card:hover { box-shadow: 0 6px 20px rgba(16,43,63,.08); transform: translateY(-2px) }
.ins-pay-icon { font-size: 1.75rem; display: block; margin-bottom: .75rem }
.ins-pay-title { font-size: var(--font-size-base); font-weight: 700; color: var(--color-primary); margin: 0 0 .5rem }
.ins-pay-body { font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0; line-height: 1.65 }

@media(prefers-reduced-motion:reduce){ .ins-card,.ins-pay-card { transition:none; transform:none } }
</style>
